source "https://rubygems.org"

# GitHub Pages pins Jekyll and most plugins. Use this for build parity
# with the GH Pages build environment. Check current version at:
# https://pages.github.com/versions/
gem "github-pages", group: :jekyll_plugins

group :jekyll_plugins do
  # Required by Minimal Mistakes for caching includes
  gem "jekyll-include-cache"
end
